{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://assesslite.dev/schema/audit-v0.1.json",
  "title": "Structural audit file (core spec v0.1)",
  "type": "object",
  "required": ["spec_version", "analysis", "structure", "ledger", "estimate", "tests", "decision", "provenance"],
  "properties": {
    "spec_version": { "const": "0.1" },
    "analysis": {
      "type": "object",
      "required": ["unit", "outcome", "exposure", "estimand", "estimator", "scale"],
      "properties": {
        "unit": { "type": "string" },
        "outcome": { "type": "string" },
        "exposure": { "type": "string" },
        "covariates": { "type": "array", "items": { "type": "string" } },
        "estimand": { "type": "string" },
        "estimator": { "type": "string" },
        "scale": { "type": "string", "description": "natural scale of estimates, e.g. log hazard ratio" }
      }
    },
    "structure": {
      "type": "object",
      "properties": {
        "cluster": { "type": ["string", "null"] },
        "time": { "type": ["string", "null"] },
        "subgroups": { "type": "array", "items": { "type": "string" } },
        "coords": { "type": ["array", "null"], "items": { "type": "string" } },
        "unit_id": { "type": ["string", "null"] },
        "n_edges": { "type": ["integer", "null"] }
      }
    },
    "ledger": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["invariance", "status", "rationale", "licenses"],
        "properties": {
          "invariance": { "type": "string" },
          "status": { "enum": ["assumed", "rejected"] },
          "rationale": { "type": "string" },
          "licenses": { "type": "string" },
          "tested": { "type": "boolean" },
          "verdict": { "enum": ["stable", "unstable", "not_resolvable", null] }
        }
      }
    },
    "estimate": {
      "type": "object",
      "required": ["value", "se", "ci_low", "ci_high", "n"],
      "properties": {
        "value": { "type": "number" },
        "se": { "type": "number" },
        "ci_low": { "type": "number" },
        "ci_high": { "type": "number" },
        "n": { "type": "integer" }
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["test", "invariance", "verdict", "reading"],
        "properties": {
          "test": { "type": "string" },
          "invariance": { "type": "string" },
          "verdict": { "enum": ["stable", "unstable", "not_resolvable"] },
          "metrics": {
            "type": "object",
            "properties": {
              "max_shift_z": { "type": ["number", "null"] },
              "shift_p_bonf": { "type": ["number", "null"] },
              "sign_flips_resolved": { "type": "integer" },
              "sign_flips_unresolved": { "type": "integer" },
              "mds": { "type": ["number", "null"] },
              "null_crossings": { "type": "integer" }
            }
          },
          "variants": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["label", "estimate", "se", "ci_low", "ci_high", "n"],
              "properties": {
                "label": { "type": "string" },
                "estimate": { "type": "number" },
                "se": { "type": ["number", "null"] },
                "ci_low": { "type": ["number", "null"] },
                "ci_high": { "type": ["number", "null"] },
                "n": { "type": "integer" }
              }
            }
          },
          "sensitivity": {
            "type": "object",
            "description": "present instead of variants for a sensitivity attack (e.g. E-value)",
            "properties": {
              "e_value_point": { "type": ["number", "null"] },
              "e_value_ci": { "type": ["number", "null"] },
              "rr_point": { "type": ["number", "null"] },
              "rr_ci_low": { "type": ["number", "null"] },
              "rr_ci_high": { "type": ["number", "null"] },
              "benchmark": { "type": ["number", "null"] }
            }
          },
          "implications": {
            "type": "array",
            "description": "present for a graph_check attack: the DAG's implied conditional independencies and their test outcomes",
            "items": {
              "type": "object",
              "required": ["claim", "status"],
              "properties": {
                "claim": { "type": "string" },
                "conditioning": { "type": "array", "items": { "type": "string" } },
                "partial_r": { "type": ["number", "null"] },
                "p_value": { "type": ["number", "null"] },
                "n": { "type": ["integer", "null"] },
                "status": { "enum": ["consistent", "violated", "not_resolvable", "not_testable"] }
              }
            }
          },
          "scenarios": {
            "type": "object",
            "description": "present for a confounding_scenarios attack: the bias-analysis array",
            "properties": {
              "target": { "type": ["number", "null"] },
              "confounder_prevalence": { "type": ["number", "null"] },
              "plausible_rr_uy": { "type": ["number", "null"] },
              "plausible_delta": { "type": ["number", "null"] },
              "minimal_tipping": { "type": ["object", "null"] },
              "cells": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "rr_uy": { "type": "number" },
                    "delta": { "type": "number" },
                    "bias_factor": { "type": "number" },
                    "adjusted_estimate": { "type": "number" },
                    "tips": { "type": "boolean" }
                  }
                }
              }
            }
          },
          "overlap": {
            "type": "object",
            "description": "present for a positivity_check attack: propensity overlap diagnostic",
            "properties": {
              "frac_extreme": { "type": ["number", "null"] },
              "n_extreme": { "type": ["integer", "null"] },
              "n": { "type": ["integer", "null"] }
            }
          },
          "spillover": {
            "type": "object",
            "description": "present for an interference_check attack: the neighbour-exposure (spillover) assessment",
            "properties": {
              "neighbor_exposure_coef": { "type": ["number", "null"] },
              "ci_low": { "type": ["number", "null"] },
              "ci_high": { "type": ["number", "null"] },
              "exposure_estimate": { "type": ["number", "null"] },
              "exposure_estimate_adjusted": { "type": ["number", "null"] },
              "n_with_neighbors": { "type": ["integer", "null"] }
            }
          },
          "adjustment": {
            "type": "object",
            "description": "present for an adjustment_check attack: the backdoor-criterion assessment of the adjusted covariate set",
            "properties": {
              "exposure": { "type": ["string", "null"] },
              "outcome": { "type": ["string", "null"] },
              "adjusted": { "type": "array", "items": { "type": "string" } },
              "sufficient_set": { "type": "array", "items": { "type": "string" } },
              "missing": { "type": "array", "items": { "type": "string" } },
              "over_adjustment": { "type": "array", "items": { "type": "string" } },
              "valid": { "type": ["boolean", "null"] },
              "identifiable": { "type": ["boolean", "null"] },
              "open_backdoor": { "type": ["boolean", "null"] }
            }
          },
          "reading": { "type": "string" }
        }
      }
    },
    "decision": {
      "type": "object",
      "required": ["status", "rationale", "load_bearing", "exposed_surface"],
      "properties": {
        "status": { "enum": ["proceed", "conditional", "abstain"] },
        "rationale": { "type": "string" },
        "load_bearing": {
          "type": "array", "items": { "type": "string" },
          "description": "assumed invariances that were attacked and came back stable"
        },
        "exposed_surface": {
          "type": "array", "items": { "type": "string" },
          "description": "assumed invariances untested or not resolvable"
        },
        "broken_by": { "type": ["string", "null"], "description": "test that produced the abstention, if any" },
        "abstention_rules": { "type": "object" }
      }
    },
    "lattice": {
      "type": "object",
      "description": "optional pooling assumption lattice: the exposure estimate under every pool-or-stratify choice",
      "required": ["axes", "nodes", "verdict"],
      "properties": {
        "axes": { "type": "array", "items": { "type": "string" } },
        "variables": { "type": "object" },
        "verdict": { "enum": ["stable", "unstable", "not_resolvable"] },
        "reading": { "type": "string" },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["pooled", "estimate", "status"],
            "properties": {
              "pooled": { "type": "array", "items": { "type": "string" } },
              "stratified": { "type": "array", "items": { "type": "string" } },
              "n_pooled": { "type": "integer" },
              "estimate": { "type": "number" },
              "ci_low": { "type": "number" },
              "ci_high": { "type": "number" },
              "n": { "type": "integer" },
              "status": { "enum": ["consistent", "attenuated", "reversed"] }
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["created", "engine", "engine_version", "spec_version", "data_fingerprint"],
      "properties": {
        "created": { "type": "string", "format": "date-time" },
        "engine": { "type": "string" },
        "engine_version": { "type": "string" },
        "platform": { "type": "string" },
        "spec_version": { "type": "string" },
        "data_fingerprint": {
          "type": "object",
          "properties": {
            "n_rows": { "type": "integer" },
            "n_cols": { "type": "integer" },
            "md5": { "type": "string" }
          }
        }
      }
    }
  }
}
